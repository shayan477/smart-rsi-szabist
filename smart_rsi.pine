//@version=5
// ============================================================================
// Smart-RSI Strategy (Improved RSI-2 Mean Reversion) — SZABIST Final Project
// Muhammad Shayan Shahid (2212325) | Muhammad Amir (2212295) | Instructor: Asif Khalid
//
// NOVEL ADDITION: "Volatility-Scaled Entry" (VSE)
//   The classic RSI-2 uses ONE fixed oversold threshold in all conditions.
//   Smart-RSI makes the entry threshold ADAPT to current volatility:
//     - calm market  -> require a DEEPER dip (stricter, avoids false signals)
//     - volatile market -> loosen slightly (catches sharper, higher-payoff bounces)
//   This volatility-scaled RSI-2 entry is our own contribution.
//
// HOW TO USE:
//   tradingview.com -> SPY chart -> 1D timeframe -> press Alt+Z (Pine Editor)
//   paste this -> "Add to chart". Green triangle = BUY (dip), red = SELL (exit).
//   Stats panel (top-right) shows a live backtest on the visible history.
//
// IMPROVEMENTS over classic RSI-2:
//   1. Volatility-Scaled Entry (the novel part)
//   2. RSI-based exit (hold until momentum recovers) instead of MA-5 exit
//   3. ATR stop-loss for dips that keep falling
// ============================================================================

indicator("Smart-RSI [SZABIST]", overlay = true, max_labels_count = 500)

// ---------------- Inputs ----------------
grpC="Core"
rsiLen   = input.int(2,   "RSI length",            group=grpC, minval=1)
trendLen = input.int(200, "Trend MA length",       group=grpC, minval=10)
baseEntry= input.float(15,"Base entry RSI level",  group=grpC, step=1)
rsiExit  = input.float(80,"RSI exit level",        group=grpC, step=1)

grpV="Novel: Volatility-Scaled Entry"
useVSE   = input.bool(true, "Enable Volatility-Scaled Entry", group=grpV)
volLen   = input.int(100,  "Volatility lookback",  group=grpV, minval=20)
vseSpan  = input.float(5,  "Max threshold shift",  group=grpV, step=1, tooltip="How much the entry RSI can move up/down with volatility")

grpR="Risk"
stopATR  = input.float(3.0,"ATR stop (x ATR)",     group=grpR, step=0.5)
atrLen   = input.int(14,   "ATR length",           group=grpR)

// ---------------- Indicators ----------------
r   = ta.rsi(close, rsiLen)
ma  = ta.sma(close, trendLen)
atr = ta.atr(atrLen)

// --- Volatility-Scaled Entry (NOVEL) ---
// Normalised volatility: current ATR% vs its own recent range (0 = calm, 1 = very volatile)
atrPct  = atr / close * 100
loVol   = ta.lowest(atrPct, volLen)
hiVol   = ta.highest(atrPct, volLen)
volNorm = hiVol > loVol ? (atrPct - loVol) / (hiVol - loVol) : 0.5
// calm (volNorm~0) -> stricter (lower RSI needed). volatile (volNorm~1) -> looser (higher RSI ok).
entryLevel = useVSE ? baseEntry - vseSpan + (2 * vseSpan) * volNorm : baseEntry

uptrend = close > ma

// ---------------- Strategy state ----------------
var bool inPos   = false
var float entryP = na
var float stopP  = na

// remember if we were already in a position BEFORE this bar, so exits are
// only checked on bars AFTER entry (prevents same-bar buy+sell artefacts)
wasInPos = inPos

buy = (not inPos) and uptrend and r < entryLevel
if buy
    inPos := true
    entryP := close
    stopP  := close - stopATR * atr

// exits only valid if we were already holding at the start of this bar
stopHit = wasInPos and inPos and low <= stopP
rsiOut  = wasInPos and inPos and r >= rsiExit
sell    = stopHit or rsiOut

if sell
    inPos := false
    entryP := na
    stopP  := na

// ---------------- Plotting ----------------
plot(ma, "Trend MA (200)", color=color.new(#2962ff, 0), linewidth=2)
plotshape(buy,     title="BUY",       style=shape.triangleup,   location=location.belowbar, color=color.new(#16a085,0), size=size.tiny, text="BUY",  textcolor=color.new(#16a085,0))
plotshape(rsiOut,  title="SELL (RSI)",style=shape.triangledown, location=location.abovebar, color=color.new(#f23645,0), size=size.tiny, text="SELL", textcolor=color.new(#f23645,0))
plotshape(stopHit, title="STOP",      style=shape.xcross,       location=location.abovebar, color=color.new(#ff9800,0), size=size.tiny, text="STOP", textcolor=color.new(#ff9800,0))
bgcolor(inPos ? color.new(#16a085, 94) : na)

// ---------------- Live backtest stats ----------------
var int   nTrades = 0
var int   nWins   = 0
var float cumRet  = 0.0
var float lastEntry = na
if buy
    lastEntry := close
if sell and not na(lastEntry)
    tr = (close - lastEntry) / lastEntry
    nTrades += 1
    nWins   += tr > 0 ? 1 : 0
    cumRet  += tr
    lastEntry := na

cHead=#1E222D, cRow=#131722, cTxt=#D1D4DC, cMut=#8A93A6, cUp=#16a085, cDn=#f23645
var table t = table.new(position.top_right, 2, 6, bgcolor=cRow, border_width=1, border_color=#2A2E39, frame_width=1, frame_color=#2A2E39)
if barstate.islast
    table.cell(t,0,0,"Smart-RSI", text_color=#FFFFFF, bgcolor=cHead, text_size=size.normal, text_halign=text.align_left)
    table.cell(t,1,0,syminfo.ticker+" "+timeframe.period, text_color=cMut, bgcolor=cHead, text_size=size.small)
    table.cell(t,0,1,"Trades", text_color=cMut, bgcolor=cRow, text_size=size.small, text_halign=text.align_left)
    table.cell(t,1,1,str.tostring(nTrades), text_color=cTxt, bgcolor=cRow, text_size=size.small)
    wr = nTrades>0 ? nWins*100.0/nTrades : 0
    table.cell(t,0,2,"Win rate", text_color=cMut, bgcolor=cRow, text_size=size.small, text_halign=text.align_left)
    table.cell(t,1,2,str.tostring(wr,"#.1")+"%", text_color=wr>=50?cUp:cDn, bgcolor=cRow, text_size=size.small)
    table.cell(t,0,3,"Sum of returns", text_color=cMut, bgcolor=cRow, text_size=size.small, text_halign=text.align_left)
    table.cell(t,1,3,str.tostring(cumRet*100,"#.1")+"%", text_color=cumRet>=0?cUp:cDn, bgcolor=cRow, text_size=size.small)
    table.cell(t,0,4,"Entry level (now)", text_color=cMut, bgcolor=cRow, text_size=size.small, text_halign=text.align_left)
    table.cell(t,1,4,str.tostring(entryLevel,"#.1"), text_color=cTxt, bgcolor=cRow, text_size=size.small)
    table.cell(t,0,5,"RSI(2) now", text_color=cMut, bgcolor=cRow, text_size=size.small, text_halign=text.align_left)
    table.cell(t,1,5,str.tostring(r,"#.1"), text_color=cTxt, bgcolor=cRow, text_size=size.small)

alertcondition(buy, "Smart-RSI BUY", "Smart-RSI buy (dip) on {{ticker}}")
alertcondition(sell,"Smart-RSI SELL","Smart-RSI exit on {{ticker}}")
